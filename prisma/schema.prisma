// Schema bazy danych Prismy — źródło prawdy o strukturze danych.
// Po każdej zmianie tutaj uruchom: npx prisma migrate dev --name <opis>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ════════════════════════════════════════════════════════════════
//  Profile — rozszerzenie tabeli auth.users z Supabase
// ════════════════════════════════════════════════════════════════
model Profile {
  id String @id @db.Uuid

  email       String    @unique
  nickname    String?
  bio         String?
  avatarUrl   String?   @map("avatar_url")
  role        Role      @default(USER)
  permissions String[]  @default([])
  lastSeenAt  DateTime? @map("last_seen_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relacje (rosną razem z aplikacją)
  posts Post[]

  @@map("profiles")
}

enum Role {
  MASTER
  ADMIN
  USER
}

// ════════════════════════════════════════════════════════════════
//  Post — wpis blogowy
// ════════════════════════════════════════════════════════════════
model Post {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String    @db.VarChar(200)
  content   String    @db.Text
  imageUrl  String?   @map("image_url")  // null dopóki nie dodamy uploadu w Round 2B
  authorId  String    @db.Uuid @map("author_id")
  author    Profile   @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at")
  editedAt  DateTime? @map("edited_at")

  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@map("posts")
}
